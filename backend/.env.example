# --- Required ---------------------------------------------------------

# Port the Express server listens on.
PORT=4000

# MongoDB connection string. Local example: mongodb://localhost:27017/sitemind
MONGODB_URI=

# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
JWT_SECRET=

# Groq API key for all AI agents and RAG chat.
GROQ_API_KEY=

# Groq model used by the analysis/chat pipeline.
GROQ_MODEL=openai/gpt-oss-120b

# The frontend's origin, for CORS. Must match exactly (no trailing slash).
FRONTEND_URL=http://localhost:3000

# --- Optional ----------------------------------------------------------

# Voyage AI key for real semantic embeddings. Without it, RAG retrieval
# still runs end-to-end on a deterministic (non-semantic) fallback.
VOYAGE_API_KEY=
